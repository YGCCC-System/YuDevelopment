# Copy to .env.local for local dev, and set the same vars in the Vercel dashboard
# (Project -> Settings -> Environment Variables).
#
# IMPORTANT: SANITY_API_TOKEN is a WRITE token. Never commit it, never expose it
# in client-side code. It only lives in serverless functions (api/*).

SANITY_PROJECT_ID=ymrsfmvq
SANITY_DATASET=production

# Sanity write token (create at https://manage.sanity.io -> API -> Tokens, "Editor" role)
SANITY_API_TOKEN=

# Password required to save changes from the /admin page (choose your own)
ADMIN_PASSWORD=

# Public Mapbox token (pk.*) for the Projects map. NEXT_PUBLIC_ vars are exposed
# to the browser by design — use a public token, not a secret one.
NEXT_PUBLIC_MAPBOX_TOKEN=
